{
    "version": 3,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 21,
        "patch": 0
    },
  "configurePresets": [
    {
      "name": "common",
      "hidden": true,
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "SKSE_SUPPORT_XBYAK": "ON",
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CONFIGURATION_TYPES": "Release"
      }
    },
    {
      "name": "vcpkg",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": {
          "type": "STRING",
          "value": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
        },
        "VCPKG_OVERLAY_PORTS": {
          "type": "STRING",
          "value": "${sourceDir}/cmake/ports/"
        },
        "VCPKG_TARGET_TRIPLET": "x64-windows-static-md"
      }
    },
    {
      "name": "x64",
      "hidden": true,
      "architecture": "x64",
      "cacheVariables": {
        "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreaded$<$<CONFIG:Debug>:Debug>DLL"
      }
    },
    {
      "name": "msvc",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_CXX_FLAGS": "/permissive- /Zc:preprocessor /EHsc /MP /W4 /external:anglebrackets /external:W0 /bigobj"
      },
      "generator": "Visual Studio 17 2022",
      "vendor": {
        "microsoft.com/VisualStudioSettings/CMake/1.0": {
          "intelliSenseMode": "windows-msvc-x64",
          "enableMicrosoftCodeAnalysis": true,
          "enableClangTidyCodeAnalysis": true
        }
      }
    },
    {
      "name": "flat",
      "hidden": true,
      "cacheVariables": {
        "ENABLE_SKYRIM_VR": "OFF",
        "VCPKG_MANIFEST_DIR": "${sourceDir}/manifests/flatrim"
      }
    },
    {
      "name": "vr",
      "hidden": true,
      "cacheVariables": {
        "ENABLE_SKYRIM_VR": "ON",
        "VCPKG_MANIFEST_DIR": "${sourceDir}/manifests/vr"
      }
    },
    {
      "name": "avx",
      "hidden": true,
      "cacheVariables": {
        "SIMD_LEVEL": "AVX"
      }
    },
    {
      "name": "avx2",
      "hidden": true,
      "cacheVariables": {
        "SIMD_LEVEL": "AVX2"
      }
    },
    {
      "name": "avx512",
      "hidden": true,
      "cacheVariables": {
        "SIMD_LEVEL": "AVX512"
      }
    },
    {
      "name": "Release-AVX-Flatrim",
      "inherits": [
        "common",
        "vcpkg",
        "x64",
        "msvc",
        "avx",
        "flat"
      ]
    },
    {
      "name": "Release-AVX-VR",
      "inherits": [
        "common",
        "vcpkg",
        "x64",
        "msvc",
        "avx",
        "vr"
      ]
    },
    {
      "name": "Release-AVX2-Flatrim",
      "inherits": [
        "common",
        "vcpkg",
        "x64",
        "msvc",
        "avx2",
        "flat"
      ]
    },
    {
      "name": "Release-AVX2-VR",
      "inherits": [
        "common",
        "vcpkg",
        "x64",
        "msvc",
        "avx2",
        "vr"
      ]
    },
    {
      "name": "Release-AVX512-Flatrim",
      "inherits": [
        "common",
        "vcpkg",
        "x64",
        "msvc",
        "avx512",
        "flat"
      ]
    },
    {
      "name": "Release-AVX512-VR",
      "inherits": [
        "common",
        "vcpkg",
        "x64",
        "msvc",
        "avx512",
        "vr"
      ]
    }
  ]
}
